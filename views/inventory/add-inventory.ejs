<h1><%= title %></h1>
<%- messages() %>

<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<form action="/inv/add-inventory" method="post" id="addInvForm" class="form-container">
  <fieldset>

    <label for="classificationList">Classification <span class="required" aria-label="required">*</span></label>
    <%- classificationList %>

    <label for="inv_make">Make <span class="required" aria-label="required">*</span></label>
    <input
      type="text"
      name="inv_make"
      id="inv_make"
      placeholder="Min of 3 characters"
      required
      minlength="3"
      autocomplete="off"
      value="<%= locals.inv_make || '' %>"
    >

    <label for="inv_model">Model <span class="required" aria-label="required">*</span></label>
    <input
      type="text"
      name="inv_model"
      id="inv_model"
      placeholder="Min of 3 characters"
      required
      minlength="3"
      autocomplete="off"
      value="<%= locals.inv_model || '' %>"
    >

    <label for="inv_description">Description <span class="required" aria-label="required">*</span></label>
    <textarea
      name="inv_description"
      id="inv_description"
      required
      autocomplete="off"
    ><%= locals.inv_description || '' %></textarea>

    <label for="inv_image">Image Path <span class="required" aria-label="required">*</span></label>
    <input
      type="text"
      name="inv_image"
      id="inv_image"
      required
      autocomplete="off"
      value="<%= locals.inv_image || '/images/vehicles/no-image.png' %>"
    >

    <label for="inv_thumbnail">Thumbnail Path <span class="required" aria-label="required">*</span></label>
    <input
      type="text"
      name="inv_thumbnail"
      id="inv_thumbnail"
      required
      autocomplete="off"
      value="<%= locals.inv_thumbnail || '/images/vehicles/no-image-tn.png' %>"
    >

    <label for="inv_price">Price <span class="required" aria-label="required">*</span></label>
    <input
      type="number"
      name="inv_price"
      id="inv_price"
      placeholder="decimal or integer"
      required
      min="0"
      autocomplete="off"
      value="<%= locals.inv_price || '' %>"
    >

    <label for="inv_year">Year <span class="required" aria-label="required">*</span></label>
    <input
      type="number"
      name="inv_year"
      id="inv_year"
      placeholder="4-digit year"
      required
      min="1900"
      max="2099"
      autocomplete="off"
      value="<%= locals.inv_year || '' %>"
    >

    <label for="inv_miles">Miles <span class="required" aria-label="required">*</span></label>
    <input
      type="number"
      name="inv_miles"
      id="inv_miles"
      placeholder="digits only"
      required
      min="0"
      autocomplete="off"
      value="<%= locals.inv_miles || '' %>"
    >

    <label for="inv_color">Color <span class="required" aria-label="required">*</span></label>
    <input
      type="text"
      name="inv_color"
      id="inv_color"
      placeholder="vehicle color"
      required
      minlength="3"
      autocomplete="off"
      value="<%= locals.inv_color || '' %>"
    >

    <button type="submit">Add Vehicle</button>
  </fieldset>
</form>